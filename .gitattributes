# Normalise line endings to LF in the repository for all text files.
* text=auto eol=lf

# Python source
*.py text eol=lf

# Config / docs
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
.env* text eol=lf
.gitignore text eol=lf

# Binary — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.zip binary
*.db binary
