# .env.example
# Copy this file to .env and edit the values for local development.
# On Kaggle, set environment variables directly in the notebook cell.

# ── I/O ─────────────────────────────────────────────────────────────────────
INPUT_ZIP=chapter.zip
OUTPUT_ZIP=cleaned_chapter.zip
WORK_DIR=_work

# ── OCR ─────────────────────────────────────────────────────────────────────
OCR_BACKEND=easyocr
# OCR_LANGUAGES=["ko","ja","ch_sim","en"]
CONFIDENCE_THRESHOLD=0.5

# ── Language filtering ───────────────────────────────────────────────────────
REMOVE_ENGLISH=false
# TARGET_SCRIPTS=["Hangul","Hiragana","Katakana","CJK"]

# ── Masking ──────────────────────────────────────────────────────────────────
MASK_EXPANSION_PX=4

# ── Patch extraction ─────────────────────────────────────────────────────────
PATCH_PADDING=32
PATCH_ALIGN=8
MAX_PATCH_SIZE=1024

# ── Inpainting ───────────────────────────────────────────────────────────────
INPAINTING_BACKEND=lama
GPU_DEVICE=cuda

# ── Output quality ───────────────────────────────────────────────────────────
JPEG_QUALITY=95

# ── Validation ───────────────────────────────────────────────────────────────
ENABLE_VALIDATOR=true
VALIDATOR_TOLERANCE=2

# ── State / resumability ─────────────────────────────────────────────────────
MANIFEST_PATH=_work/manifest.db
RESUME=true

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG_MODE=false
DEBUG_DIR=_debug
